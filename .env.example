# ─── Core ───────────────────────────────────────────────
NODE_ENV=development
WEB_ORIGIN=http://localhost:3000
API_PORT=4000
API_PREFIX=/api/v1

# ─── MongoDB ────────────────────────────────────────────
# Docker (default): set Atlas URI in root .env — local `mongo` service is disabled unless you run:
#   docker compose --profile local-mongo up -d mongo
MONGO_URI=mongodb://mongo:27017/planiq?replicaSet=rs0

# ─── Redis (BullMQ + rate limit) ────────────────────────
REDIS_URL=redis://redis:6379

# ─── Auth ───────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
COOKIE_DOMAIN=localhost

# ─── AWS S3 (leave S3_ENDPOINT empty for native AWS) ───
S3_ENDPOINT=
S3_REGION=eu-central-1
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=false
S3_PUBLIC_URL=

# ─── AI / CV service ────────────────────────────────────
AI_SERVICE_URL=http://ai:8000
AI_TIMEOUT_MS=120000
AI_RASTER_DPI=200
AI_ENABLE_DWG=false
# Vision-LLM fallback is DISABLED by default. Options: disabled|openai|gemini|claude
AI_FALLBACK_PROVIDER=disabled
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Limits / security ──────────────────────────────────
UPLOAD_MAX_MB=50
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX=120
LOG_LEVEL=info

# ─── Web (Next.js public) ───────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1