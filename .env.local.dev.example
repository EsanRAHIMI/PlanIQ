# Local hybrid dev (web/api/worker run with pnpm on host)
NODE_ENV=development
WEB_ORIGIN=http://localhost:3000
API_PORT=4000
API_PREFIX=/api/v1

# MongoDB Atlas (required)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# Infra from docker-compose.infra.yml
REDIS_URL=redis://localhost:6379
S3_ENDPOINT=http://localhost:9100
S3_REGION=us-east-1
S3_BUCKET=planiq
S3_ACCESS_KEY=planiq
S3_SECRET_KEY=planiq-secret
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_URL=http://localhost:9100

# AI service (Docker or local python)
AI_SERVICE_URL=http://localhost:8000
AI_TIMEOUT_MS=120000
AI_RASTER_DPI=200
AI_ENABLE_DWG=false
AI_FALLBACK_PROVIDER=disabled

# Auth
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
COOKIE_DOMAIN=localhost

# Limits / logging
UPLOAD_MAX_MB=50
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX=120
LOG_LEVEL=info

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
